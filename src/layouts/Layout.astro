---
import "../styles/global.css";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import WhatsAppFloat from "../components/WhatsAppFloat.astro";
import { getLang } from "../i18n/utils";

interface Props {
  title: string;
  description?: string;
  lang: string;
  transparentHeader?: boolean;
}

const { title, description = "", lang: rawLang, transparentHeader = false } = Astro.props;
const lang = getLang(rawLang);
const fullTitle = title ? `${title} — Softtin` : "Softtin";
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/png" href="/logo-softtin.png" />
    <title>{fullTitle}</title>
    {description && <meta name="description" content={description} />}
    <meta property="og:title" content={fullTitle} />
    {description && <meta property="og:description" content={description} />}
    <meta property="og:type" content="website" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap"
      rel="stylesheet"
    />
  </head>
  <body class="bg-white text-brand-950 antialiased">
    <Header lang={lang} transparent={transparentHeader} />
    <main class={transparentHeader ? "" : "pt-16 md:pt-20"}>
      <slot />
    </main>
    <Footer lang={lang} />
    <WhatsAppFloat lang={lang} />
  </body>
</html>
