---
import { getCollection, type CollectionEntry } from "astro:content";
import Layout from "../../../layouts/Layout.astro";
import ProductCard from "../../../components/ProductCard.astro";
import { getLang, useTranslations, localizePath, formatPrice } from "../../../i18n/utils";
import { waLink } from "../../../config";
import { ui } from "../../../i18n/ui";

export async function getStaticPaths() {
  const products = await getCollection("products");
  const langs = ["id", "en"] as const;
  return products.flatMap((product) =>
    langs.map((lang) => ({
      params: { lang, slug: product.id },
      props: { product },
    }))
  );
}

interface Props {
  product: CollectionEntry<"products">;
}

const { product } = Astro.props;
const lang = getLang(Astro.params.lang);
const t = useTranslations(lang);
const d = product.data;

const name = d.name[lang];
const price = formatPrice(d.price);
const original = d.originalPrice ? formatPrice(d.originalPrice) : null;
const image = d.images[0] ? `/products/${d.images[0]}` : "/products/placeholder.svg";
const specs = d.specs?.[lang] ?? [];
const orderHref = waLink(`${ui[lang]["wa.orderPrefix"]} ${name} (${price})`);

// Produk lain (maksimal 3) untuk bagian "produk lainnya".
const related = (await getCollection("products"))
  .filter((p) => p.id !== product.id)
  .sort((a, b) => a.data.order - b.data.order)
  .slice(0, 3);
---

<Layout lang={lang} title={name} description={d.description[lang]}>
  <div class="container-soft py-6 text-sm text-brand-500">
    <a href={localizePath("/produk", lang)} class="hover:text-brand-700">{t("nav.products")}</a>
    <span class="mx-2">/</span>
    <span class="text-brand-800">{name}</span>
  </div>

  <section class="container-soft grid gap-10 pb-8 lg:grid-cols-2">
    <div class="overflow-hidden rounded-3xl border border-brand-100 bg-brand-50">
      <img src={image} alt={name} class="aspect-[4/3] w-full object-cover" />
    </div>

    <div class="flex flex-col">
      <h1 class="text-3xl font-extrabold text-brand-900 md:text-4xl">{name}</h1>
      {d.tagline && <p class="mt-2 text-brand-700/80">{d.tagline[lang]}</p>}
      <div class="mt-5 flex flex-wrap items-baseline gap-x-3">
        {original && <span class="text-xl font-medium text-brand-400 line-through">{original}</span>}
        <span class="text-3xl font-extrabold text-brand-600">{price}</span>
      </div>
      <p class="mt-5 leading-relaxed text-brand-800/90">{d.description[lang]}</p>

      {
        specs.length > 0 && (
          <div class="mt-7">
            <h2 class="text-sm font-bold uppercase tracking-wide text-brand-900">{t("products.specs")}</h2>
            <ul class="mt-3 space-y-2">
              {specs.map((s) => (
                <li class="flex items-start gap-2.5 text-sm text-brand-800">
                  <svg class="mt-0.5 shrink-0 text-brand-500" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12.5l4 4 10-10"/></svg>
                  {s}
                </li>
              ))}
            </ul>
          </div>
        )
      }

      <div class="mt-8 flex flex-col gap-3 sm:flex-row">
        <a
          href={orderHref}
          target="_blank"
          rel="noopener"
          class="flex-1 rounded-full bg-brand-500 px-7 py-3.5 text-center text-sm font-semibold text-white shadow-md transition-colors hover:bg-brand-600"
        >
          {t("cta.buy")}
        </a>
        <a
          href={localizePath("/produk", lang)}
          class="flex-1 rounded-full border border-brand-300 px-7 py-3.5 text-center text-sm font-semibold text-brand-700 transition-colors hover:bg-brand-50"
        >
          {t("cta.viewProducts")}
        </a>
      </div>
    </div>
  </section>

  {
    related.length > 0 && (
      <section class="container-soft py-16">
        <h2 class="mb-8 text-2xl font-extrabold text-brand-900">{t("products.related")}</h2>
        <div class="grid gap-7 sm:grid-cols-2 lg:grid-cols-3">
          {related.map((p) => (
            <ProductCard product={p} lang={lang} />
          ))}
        </div>
      </section>
    )
  }
</Layout>
