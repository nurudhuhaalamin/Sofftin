---
import Layout from "../../layouts/Layout.astro";
import { getLang, useTranslations } from "../../i18n/utils";
import { SITE, waLink } from "../../config";
import { ui } from "../../i18n/ui";

export function getStaticPaths() {
  return [{ params: { lang: "id" } }, { params: { lang: "en" } }];
}

const lang = getLang(Astro.params.lang);
const t = useTranslations(lang);
const orderHref = waLink(ui[lang]["wa.general"]);
const waDisplay = "+" + SITE.whatsappNumber;
---

<Layout lang={lang} title={t("contact.title")} description={t("contact.subtitle")}>
  <section class="bg-gradient-to-b from-brand-50 to-white">
    <div class="container-soft py-14 text-center md:py-16">
      <h1 class="text-3xl font-extrabold text-brand-900 md:text-4xl">{t("contact.title")}</h1>
      <p class="mx-auto mt-3 max-w-xl text-brand-700/80">{t("contact.subtitle")}</p>
    </div>
  </section>

  <section class="container-soft py-14">
    <div class="mx-auto grid max-w-3xl gap-6 sm:grid-cols-3">
      <div class="rounded-2xl border border-brand-100 bg-white p-6 text-center shadow-sm">
        <p class="text-xs font-bold uppercase tracking-wide text-brand-500">{t("contact.waLabel")}</p>
        <a href={orderHref} target="_blank" rel="noopener" class="mt-2 block font-semibold text-brand-900 hover:text-brand-500">{waDisplay}</a>
      </div>
      <div class="rounded-2xl border border-brand-100 bg-white p-6 text-center shadow-sm">
        <p class="text-xs font-bold uppercase tracking-wide text-brand-500">{t("contact.emailLabel")}</p>
        <a href={`mailto:${SITE.email}`} class="mt-2 block font-semibold text-brand-900 hover:text-brand-500">{SITE.email}</a>
      </div>
      <div class="rounded-2xl border border-brand-100 bg-white p-6 text-center shadow-sm">
        <p class="text-xs font-bold uppercase tracking-wide text-brand-500">{t("contact.locationLabel")}</p>
        <p class="mt-2 font-semibold text-brand-900">{SITE.city[lang]}</p>
      </div>
    </div>

    <div class="mt-12 text-center">
      <a
        href={orderHref}
        target="_blank"
        rel="noopener"
        class="inline-block rounded-full bg-brand-500 px-8 py-3.5 text-sm font-semibold text-white shadow-md transition-colors hover:bg-brand-600"
      >
        {t("cta.askWhatsapp")}
      </a>
    </div>
  </section>
</Layout>
