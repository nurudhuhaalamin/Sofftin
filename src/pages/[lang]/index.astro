---
import { getCollection } from "astro:content";
import Layout from "../../layouts/Layout.astro";
import ProductCard from "../../components/ProductCard.astro";
import { getLang, useTranslations, localizePath } from "../../i18n/utils";
import { SITE, waLink } from "../../config";
import { ui } from "../../i18n/ui";

export function getStaticPaths() {
  return [{ params: { lang: "id" } }, { params: { lang: "en" } }];
}

const lang = getLang(Astro.params.lang);
const t = useTranslations(lang);

const all = await getCollection("products");
const featured = all
  .filter((p) => p.data.featured)
  .sort((a, b) => a.data.order - b.data.order);

const advantages = [
  { key: "1", icon: "foam" },
  { key: "2", icon: "shield" },
  { key: "3", icon: "star" },
  { key: "4", icon: "support" },
] as const;

const testimonials = [
  {
    id: { quote: "Tidur jadi jauh lebih nyenyak, persis seperti di hotel. Bantalnya empuk tapi tetap menopang.", name: "Rani P.", role: "Pelanggan" },
    en: { quote: "My sleep is so much better now, just like a hotel. The pillow is soft yet supportive.", name: "Rani P.", role: "Customer" },
  },
  {
    id: { quote: "Kualitasnya premium dan pemesanan lewat WhatsApp sangat cepat dan ramah. Recommended!", name: "Dimas A.", role: "Pelanggan" },
    en: { quote: "Premium quality and ordering via WhatsApp was fast and friendly. Recommended!", name: "Dimas A.", role: "Customer" },
  },
  {
    id: { quote: "Guling memory foam-nya bikin posisi tidur lebih rileks. Bahan adem dan tidak bau.", name: "Sinta W.", role: "Pelanggan" },
    en: { quote: "The memory foam bolster makes my sleep position so relaxed. Cool material, no odor.", name: "Sinta W.", role: "Customer" },
  },
];

const orderHref = waLink(ui[lang]["wa.general"]);
const productsHref = localizePath("/produk", lang);
---

<Layout lang={lang} title={t("hero.title")} description={t("hero.subtitle")}>
  <!-- HERO -->
  <section class="relative overflow-hidden bg-gradient-to-b from-brand-50 to-white">
    <div class="container-soft grid items-center gap-10 py-14 md:py-20 lg:grid-cols-2 lg:gap-8">
      <div>
        <span class="inline-block rounded-full bg-brand-100 px-4 py-1.5 text-xs font-bold tracking-wider text-brand-700">
          {t("hero.badge")}
        </span>
        <h1 class="mt-5 text-4xl font-extrabold leading-tight text-brand-900 md:text-5xl lg:text-6xl">
          {t("hero.title")}
        </h1>
        <p class="mt-5 max-w-xl text-base text-brand-800/80 md:text-lg">
          {t("hero.subtitle")}
        </p>
        <div class="mt-8 flex flex-col gap-3 sm:flex-row">
          <a
            href={orderHref}
            target="_blank"
            rel="noopener"
            class="rounded-full bg-brand-500 px-7 py-3.5 text-center text-sm font-semibold text-white shadow-md transition-colors hover:bg-brand-600"
          >
            {t("cta.buy")}
          </a>
          <a
            href={productsHref}
            class="rounded-full border border-brand-300 px-7 py-3.5 text-center text-sm font-semibold text-brand-700 transition-colors hover:bg-brand-50"
          >
            {t("cta.viewProducts")}
          </a>
        </div>
      </div>
      <div class="relative">
        <img src="/products/guling-lifestyle.jpg" alt={t("hero.title")} class="aspect-[4/3] w-full rounded-3xl object-cover shadow-[var(--shadow-soft)]" />
      </div>
    </div>
  </section>

  <!-- KEUNGGULAN -->
  <section id="keunggulan" class="container-soft scroll-mt-24 py-16 md:py-20">
    <div class="mx-auto max-w-2xl text-center">
      <h2 class="text-3xl font-extrabold text-brand-900 md:text-4xl">{t("adv.title")}</h2>
      <p class="mt-3 text-brand-700/80">{t("adv.subtitle")}</p>
    </div>
    <div class="mt-12 grid gap-6 sm:grid-cols-2 lg:grid-cols-4">
      {
        advantages.map((a) => (
          <div class="rounded-2xl border border-brand-100 bg-white p-6 text-center shadow-sm">
            <div class="mx-auto flex h-14 w-14 items-center justify-center rounded-2xl bg-brand-50 text-brand-500">
              {a.icon === "foam" && (
                <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="8" width="18" height="9" rx="4"/><path d="M6 8V7a3 3 0 0 1 3-3h6a3 3 0 0 1 3 3v1"/></svg>
              )}
              {a.icon === "shield" && (
                <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M12 3l7 3v5c0 4.5-3 7.5-7 9-4-1.5-7-4.5-7-9V6z"/><path d="M9.5 12l1.8 1.8L15 10"/></svg>
              )}
              {a.icon === "star" && (
                <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M12 3l2.6 5.3 5.9.9-4.3 4.1 1 5.8L12 16.9 6.8 19.2l1-5.8L3.5 9.2l5.9-.9z"/></svg>
              )}
              {a.icon === "support" && (
                <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M4 12a8 8 0 0 1 16 0v4a3 3 0 0 1-3 3h-1"/><rect x="3" y="12" width="4" height="6" rx="1.5"/><rect x="17" y="12" width="4" height="6" rx="1.5"/></svg>
              )}
            </div>
            <h3 class="mt-5 text-base font-bold text-brand-900">{t(`adv.${a.key}.title` as any)}</h3>
            <p class="mt-2 text-sm text-brand-700/80">{t(`adv.${a.key}.desc` as any)}</p>
          </div>
        ))
      }
    </div>
  </section>

  <!-- PRODUK UNGGULAN -->
  <section class="bg-brand-50/60 py-16 md:py-20">
    <div class="container-soft">
      <div class="mx-auto max-w-2xl text-center">
        <h2 class="text-3xl font-extrabold text-brand-900 md:text-4xl">{t("products.featuredTitle")}</h2>
        <p class="mt-3 text-brand-700/80">{t("products.featuredSubtitle")}</p>
      </div>
      <div class="mt-12 grid gap-7 sm:grid-cols-2 lg:grid-cols-3">
        {featured.map((product) => <ProductCard product={product} lang={lang} />)}
      </div>
      <div class="mt-10 text-center">
        <a href={productsHref} class="inline-block rounded-full border border-brand-300 px-7 py-3 text-sm font-semibold text-brand-700 transition-colors hover:bg-white">
          {t("cta.viewProducts")}
        </a>
      </div>
    </div>
  </section>

  <!-- PARTNER -->
  <section class="container-soft py-14">
    <p class="text-center text-sm font-semibold uppercase tracking-wider text-brand-500/80">{t("partners.title")}</p>
    <div class="mt-8 flex flex-wrap items-center justify-center gap-x-12 gap-y-6">
      {
        SITE.partners.map((name) => (
          <span class="text-xl font-bold tracking-wide text-brand-900/30 md:text-2xl" style="font-family: 'Plus Jakarta Sans', serif;">
            {name}
          </span>
        ))
      }
    </div>
  </section>

  <!-- TESTIMONI -->
  <section class="container-soft py-16 md:py-20">
    <div class="mx-auto max-w-2xl text-center">
      <h2 class="text-3xl font-extrabold text-brand-900 md:text-4xl">{t("testi.title")}</h2>
      <p class="mt-3 text-brand-700/80">{t("testi.subtitle")}</p>
    </div>
    <div class="mt-12 grid gap-7 md:grid-cols-3">
      {
        testimonials.map((item) => (
          <figure class="rounded-3xl border border-brand-100 bg-white p-7 shadow-sm">
            <div class="flex gap-1 text-brand-400">
              {[0, 1, 2, 3, 4].map(() => (
                <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M12 3l2.6 5.3 5.9.9-4.3 4.1 1 5.8L12 16.9 6.8 19.2l1-5.8L3.5 9.2l5.9-.9z"/></svg>
              ))}
            </div>
            <blockquote class="mt-4 text-sm leading-relaxed text-brand-800">“{item[lang].quote}”</blockquote>
            <figcaption class="mt-5 text-sm font-semibold text-brand-900">
              {item[lang].name} <span class="font-normal text-brand-500">· {item[lang].role}</span>
            </figcaption>
          </figure>
        ))
      }
    </div>
  </section>

  <!-- CTA BAWAH -->
  <section class="container-soft pb-4">
    <div class="overflow-hidden rounded-3xl bg-gradient-to-br from-brand-600 to-brand-800 px-8 py-14 text-center text-white md:px-16">
      <h2 class="text-2xl font-extrabold md:text-3xl">{t("cta.bottomTitle")}</h2>
      <p class="mx-auto mt-3 max-w-xl text-brand-100">{t("cta.bottomSubtitle")}</p>
      <a
        href={orderHref}
        target="_blank"
        rel="noopener"
        class="mt-7 inline-block rounded-full bg-white px-8 py-3.5 text-sm font-bold text-brand-700 transition-transform hover:scale-105"
      >
        {t("cta.askWhatsapp")}
      </a>
    </div>
  </section>
</Layout>
