---
import { getCollection } from "astro:content";
import Layout from "../../layouts/Layout.astro";
import FeaturedProductCard from "../../components/FeaturedProductCard.astro";
import { getLang, useTranslations, localizePath } from "../../i18n/utils";
import { SITE, waLink } from "../../config";
import { ui } from "../../i18n/ui";

export function getStaticPaths() {
  return [{ params: { lang: "id" } }, { params: { lang: "en" } }];
}

const lang = getLang(Astro.params.lang);
const t = useTranslations(lang);

const all = await getCollection("products");
const featured = all
  .filter((p) => p.data.featured)
  .sort((a, b) => a.data.order - b.data.order);

const advantages = [
  { key: "1", icon: "foam" },
  { key: "2", icon: "shield" },
  { key: "3", icon: "star" },
  { key: "4", icon: "support" },
  { key: "5", icon: "gem" },
] as const;

const testimonials = [
  {
    id: { quote: "Tidur jadi jauh lebih nyenyak, persis seperti di hotel. Bantalnya empuk tapi tetap menopang.", name: "Rani P.", role: "Pelanggan" },
    en: { quote: "My sleep is so much better now, just like a hotel. The pillow is soft yet supportive.", name: "Rani P.", role: "Customer" },
  },
  {
    id: { quote: "Kualitasnya premium dan pemesanan lewat WhatsApp sangat cepat dan ramah. Recommended!", name: "Dimas A.", role: "Pelanggan" },
    en: { quote: "Premium quality and ordering via WhatsApp was fast and friendly. Recommended!", name: "Dimas A.", role: "Customer" },
  },
  {
    id: { quote: "Guling memory foam-nya bikin posisi tidur lebih rileks. Bahan adem dan tidak bau.", name: "Sinta W.", role: "Pelanggan" },
    en: { quote: "The memory foam bolster makes my sleep position so relaxed. Cool material, no odor.", name: "Sinta W.", role: "Customer" },
  },
];

const orderHref = waLink(ui[lang]["wa.general"]);
const productsHref = localizePath("/produk", lang);
---

<Layout lang={lang} title={t("hero.title")} description={t("hero.subtitle")}>
  <!-- HERO -->
  <section class="relative overflow-hidden bg-gradient-to-b from-brand-50 to-white">
    <div class="container-soft grid items-center gap-10 py-14 md:py-20 lg:grid-cols-2 lg:gap-8">
      <div>
        <span class="inline-block rounded-full bg-brand-100 px-4 py-1.5 text-xs font-bold tracking-wider text-brand-700">
          {t("hero.badge")}
        </span>
        <h1 class="mt-5 text-3xl font-extrabold leading-tight text-brand-900 sm:text-4xl md:text-5xl lg:text-6xl">
          {t("hero.title")}
        </h1>
        <p class="mt-5 max-w-xl text-base text-brand-800/80 md:text-lg">
          {t("hero.subtitle")}
        </p>
        <div class="mt-8 flex flex-col gap-3 sm:flex-row">
          <a
            href={orderHref}
            target="_blank"
            rel="noopener"
            class="rounded-full bg-brand-500 px-7 py-3.5 text-center text-sm font-semibold text-white shadow-md transition-colors hover:bg-brand-600"
          >
            {t("cta.buy")}
          </a>
          <a
            href={productsHref}
            class="rounded-full border border-brand-300 px-7 py-3.5 text-center text-sm font-semibold text-brand-700 transition-colors hover:bg-brand-50"
          >
            {t("cta.viewProducts")}
          </a>
        </div>
      </div>
      <div class="relative">
        <img src="/products/set-bantal-guling-luxury.jpg" alt={t("hero.title")} class="aspect-[4/3] w-full rounded-3xl object-cover shadow-[var(--shadow-soft)]" />
      </div>
    </div>
  </section>

  <!-- KEUNGGULAN — strip 5 item mengambang menumpuk hero -->
  <section id="keunggulan" class="container-soft scroll-mt-24">
    <div class="relative z-10 -mt-8 grid grid-cols-2 gap-y-8 rounded-3xl border border-brand-100 bg-white px-4 py-8 shadow-[var(--shadow-soft)] sm:grid-cols-3 md:divide-x md:divide-brand-100 lg:-mt-14 lg:grid-cols-5 lg:gap-y-0">
      {
        advantages.map((a) => (
          <div class="px-4 text-center">
            <div class="mx-auto flex h-12 w-12 items-center justify-center rounded-2xl bg-brand-50 text-brand-500">
              {a.icon === "foam" && (
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="8" width="18" height="9" rx="4"/><path d="M6 8V7a3 3 0 0 1 3-3h6a3 3 0 0 1 3 3v1"/></svg>
              )}
              {a.icon === "shield" && (
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M12 3l7 3v5c0 4.5-3 7.5-7 9-4-1.5-7-4.5-7-9V6z"/><path d="M9.5 12l1.8 1.8L15 10"/></svg>
              )}
              {a.icon === "star" && (
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M12 3l2.6 5.3 5.9.9-4.3 4.1 1 5.8L12 16.9 6.8 19.2l1-5.8L3.5 9.2l5.9-.9z"/></svg>
              )}
              {a.icon === "support" && (
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M4 12a8 8 0 0 1 16 0v4a3 3 0 0 1-3 3h-1"/><rect x="3" y="12" width="4" height="6" rx="1.5"/><rect x="17" y="12" width="4" height="6" rx="1.5"/></svg>
              )}
              {a.icon === "gem" && (
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M6 3h12l3 5-9 13L3 8z"/><path d="M3 8h18M9 3l-2 5 5 13 5-13-2-5"/></svg>
              )}
            </div>
            <h3 class="mt-4 text-sm font-bold text-brand-900">{t(`adv.${a.key}.title` as any)}</h3>
            <p class="mt-1.5 text-xs leading-relaxed text-brand-700/75">{t(`adv.${a.key}.desc` as any)}</p>
          </div>
        ))
      }
    </div>
  </section>

  <!-- PRODUK UNGGULAN -->
  <section class="container-soft py-16 md:py-24">
    <div class="mx-auto max-w-2xl text-center">
      <p class="text-xs font-bold uppercase tracking-[0.2em] text-brand-500">{t("products.featuredLabel")}</p>
      <h2 class="mt-3 text-3xl font-extrabold text-brand-900 md:text-4xl">{t("products.featuredTitle")}</h2>
      <p class="mt-3 text-brand-700/80">{t("products.featuredSubtitle")}</p>
    </div>
    <div class="mx-auto mt-12 flex max-w-5xl flex-col gap-8">
      {featured.map((product) => <FeaturedProductCard product={product} lang={lang} />)}
    </div>
    <div class="mt-10 text-center">
      <a href={productsHref} class="inline-block rounded-full border border-brand-300 px-7 py-3 text-sm font-semibold text-brand-700 transition-colors hover:bg-brand-50">
        {t("cta.viewProducts")}
      </a>
    </div>
  </section>

  <!-- PARTNER -->
  <section class="border-y border-brand-100 bg-brand-50/50">
    <div class="container-soft py-12">
      <p class="text-center text-xs font-bold uppercase tracking-[0.2em] text-brand-500">{t("partners.title")}</p>
      <div class="mt-7 flex flex-wrap items-center justify-center gap-x-12 gap-y-5">
        {
          SITE.partners.map((name) => (
            <span class="text-lg font-bold tracking-wide text-brand-900/30 md:text-2xl">{name}</span>
          ))
        }
      </div>
    </div>
  </section>

  <!-- TESTIMONI — unggulan + foto -->
  <section class="container-soft py-16 md:py-24">
    <div class="mx-auto max-w-2xl text-center">
      <h2 class="text-3xl font-extrabold text-brand-900 md:text-4xl">{t("testi.title")}</h2>
      <p class="mt-3 text-brand-700/80">{t("testi.subtitle")}</p>
    </div>

    <figure class="mt-12 grid items-stretch gap-8 overflow-hidden rounded-3xl border border-brand-100 bg-white shadow-[var(--shadow-soft)] md:grid-cols-2 md:gap-0">
      <img
        src="/products/guling-lifestyle.jpg"
        alt={t("testi.title")}
        loading="lazy"
        class="h-64 w-full object-cover md:h-full"
      />
      <div class="flex flex-col justify-center p-8 md:p-12">
        <svg class="text-brand-200" width="48" height="48" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M7.5 6C5 6 3 8 3 10.5S5 15 7.5 15c.2 0 .4 0 .6-.05C7.6 16.7 6.2 18 4.5 18.4c-.4.1-.6.5-.5.9.1.4.5.7.9.6C8.6 19.1 11 16 11 12v-1.5C11 8 9 6 7.5 6zm9 0C14 6 12 8 12 10.5S14 15 16.5 15c.2 0 .4 0 .6-.05-.5 1.75-1.9 3.05-3.6 3.45-.4.1-.6.5-.5.9.1.4.5.7.9.6C17.6 19.1 20 16 20 12v-1.5C20 8 18 6 16.5 6z"/></svg>
        <div class="mt-3 flex gap-1 text-brand-400">
          {[0, 1, 2, 3, 4].map(() => (
            <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M12 3l2.6 5.3 5.9.9-4.3 4.1 1 5.8L12 16.9 6.8 19.2l1-5.8L3.5 9.2l5.9-.9z"/></svg>
          ))}
        </div>
        <blockquote class="mt-4 text-lg leading-relaxed text-brand-800 md:text-xl">
          “{testimonials[0][lang].quote}”
        </blockquote>
        <figcaption class="mt-6 text-sm font-bold text-brand-900">
          {testimonials[0][lang].name}
          <span class="font-normal text-brand-500"> · {testimonials[0][lang].role}</span>
        </figcaption>
      </div>
    </figure>
  </section>

  <!-- CTA BAWAH -->
  <section class="container-soft pb-4">
    <div class="overflow-hidden rounded-3xl bg-gradient-to-br from-brand-600 to-brand-800 px-8 py-14 text-center text-white md:px-16">
      <h2 class="text-2xl font-extrabold md:text-3xl">{t("cta.bottomTitle")}</h2>
      <p class="mx-auto mt-3 max-w-xl text-brand-100">{t("cta.bottomSubtitle")}</p>
      <a
        href={orderHref}
        target="_blank"
        rel="noopener"
        class="mt-7 inline-block rounded-full bg-white px-8 py-3.5 text-sm font-bold text-brand-700 transition-transform hover:scale-105"
      >
        {t("cta.askWhatsapp")}
      </a>
    </div>
  </section>
</Layout>
