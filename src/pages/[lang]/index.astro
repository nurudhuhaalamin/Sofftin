---
import { getCollection } from "astro:content";
import Layout from "../../layouts/Layout.astro";
import FeaturedProductCard from "../../components/FeaturedProductCard.astro";
import { getLang, useTranslations, localizePath } from "../../i18n/utils";
import { waLink } from "../../config";
import { ui } from "../../i18n/ui";

export function getStaticPaths() {
  return [{ params: { lang: "id" } }, { params: { lang: "en" } }];
}

const lang = getLang(Astro.params.lang);
const t = useTranslations(lang);

const all = await getCollection("products");
const featured = all
  .filter((p) => p.data.featured)
  .sort((a, b) => a.data.order - b.data.order);

const advantages = [
  { key: "1", icon: "foam" },
  { key: "2", icon: "shield" },
  { key: "3", icon: "star" },
  { key: "4", icon: "support" },
  { key: "5", icon: "gem" },
] as const;

const testimonials = [
  {
    id: { quote: "Leher saya tidak lagi pegal saat bangun. Bantalnya benar-benar mengikuti bentuk kepala dan terasa nyaman sepanjang malam.", name: "Rani P.", role: "Pelanggan di Jakarta" },
    en: { quote: "My neck no longer aches in the morning. The pillow truly contours to my head and feels comfortable all night.", name: "Rani P.", role: "Customer in Jakarta" },
  },
  {
    id: { quote: "Sejak menaruh gulingnya di antara lutut, tidur menyamping jadi jauh lebih nyaman dan pinggang tidak mudah sakit.", name: "Sinta W.", role: "Pelanggan di Bandung" },
    en: { quote: "Since placing the bolster between my knees, side sleeping is far more comfortable and my lower back no longer aches.", name: "Sinta W.", role: "Customer in Bandung" },
  },
  {
    id: { quote: "Kualitas bahannya terasa kokoh dan empuk, serta pemesanan lewat WhatsApp cepat dan ramah. Pelayanannya sangat memuaskan.", name: "Dimas A.", role: "Pelanggan di Surabaya" },
    en: { quote: "The material feels firm yet plush, and ordering via WhatsApp was fast and friendly. The service was very satisfying.", name: "Dimas A.", role: "Customer in Surabaya" },
  },
];

const orderHref = waLink(ui[lang]["wa.general"]);
const productsHref = localizePath("/produk", lang);
---

<Layout lang={lang} title={t("hero.title")} description={t("hero.subtitle")} transparentHeader={true}>
  <!-- HERO — foto background rasio landscape tetap (tidak ikut tinggi layar) -->
  <section class="relative flex min-h-[520px] items-center md:h-[600px] md:min-h-0 lg:h-[680px]">
    <!-- Foto background -->
    <img
      src="/products/guling-lifestyle.jpg"
      alt={t("hero.title")}
      class="absolute inset-0 h-full w-full object-cover"
    />
    <!-- Lapisan gelap agar teks terbaca konsisten di semua perangkat (apa pun crop fotonya) -->
    <div class="absolute inset-0 bg-gradient-to-r from-brand-950/85 via-brand-950/65 to-brand-950/50"></div>

    <!-- Konten -->
    <div class="container-soft relative z-10 pt-24 pb-16 md:pt-28">
      <div class="max-w-2xl text-white">
        <span class="inline-block rounded-full bg-white/15 px-4 py-1.5 text-xs font-bold tracking-wider backdrop-blur-sm">
          {t("hero.badge")}
        </span>
        <h1 class="mt-5 text-3xl font-extrabold leading-tight sm:text-4xl md:text-5xl lg:text-6xl">
          {t("hero.title")}
        </h1>
        <p class="mt-5 max-w-xl text-base text-white/85 md:text-lg">
          {t("hero.subtitle")}
        </p>
        <div class="mt-8 flex flex-col gap-3 sm:flex-row">
          <a
            href={orderHref}
            target="_blank"
            rel="noopener"
            class="rounded-full bg-brand-500 px-7 py-3.5 text-center text-sm font-semibold text-white shadow-lg transition-colors hover:bg-brand-600"
          >
            {t("cta.buy")}
          </a>
          <a
            href={productsHref}
            class="rounded-full border border-white/70 px-7 py-3.5 text-center text-sm font-semibold text-white transition-colors hover:bg-white/10"
          >
            {t("cta.viewProducts")}
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- KEUNGGULAN — strip 5 item mengambang menumpuk hero, scroll horizontal di HP -->
  <section id="keunggulan" class="container-soft scroll-mt-24">
    <div class="relative z-10 -mt-12 md:-mt-16 md:overflow-hidden md:rounded-3xl md:border md:border-brand-100 md:bg-white md:shadow-[var(--shadow-soft)]">
      <div class="no-scrollbar -mx-5 flex snap-x snap-mandatory gap-4 scroll-pl-5 overflow-x-auto px-5 py-1 md:mx-0 md:scroll-pl-0 md:gap-0 md:px-0 md:py-0 md:snap-none">
      {
        advantages.map((a) => (
          <div class={`shrink-0 basis-[85%] snap-start rounded-2xl bg-white px-5 py-8 text-center shadow-sm ring-1 ring-brand-100 sm:basis-[46%] md:flex-1 md:basis-0 md:rounded-none md:bg-transparent md:shadow-none md:ring-0 ${a.key !== "1" ? "md:border-l md:border-brand-100" : ""}`}>
            <div class="mx-auto flex h-12 w-12 items-center justify-center rounded-2xl bg-brand-50 text-brand-500">
              {a.icon === "foam" && (
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="8" width="18" height="9" rx="4"/><path d="M6 8V7a3 3 0 0 1 3-3h6a3 3 0 0 1 3 3v1"/></svg>
              )}
              {a.icon === "shield" && (
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M12 3l7 3v5c0 4.5-3 7.5-7 9-4-1.5-7-4.5-7-9V6z"/><path d="M9.5 12l1.8 1.8L15 10"/></svg>
              )}
              {a.icon === "star" && (
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M12 3l2.6 5.3 5.9.9-4.3 4.1 1 5.8L12 16.9 6.8 19.2l1-5.8L3.5 9.2l5.9-.9z"/></svg>
              )}
              {a.icon === "support" && (
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M4 12a8 8 0 0 1 16 0v4a3 3 0 0 1-3 3h-1"/><rect x="3" y="12" width="4" height="6" rx="1.5"/><rect x="17" y="12" width="4" height="6" rx="1.5"/></svg>
              )}
              {a.icon === "gem" && (
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M6 3h12l3 5-9 13L3 8z"/><path d="M3 8h18M9 3l-2 5 5 13 5-13-2-5"/></svg>
              )}
            </div>
            <h3 class="mt-4 text-sm font-bold text-brand-900">{t(`adv.${a.key}.title` as any)}</h3>
            <p class="mt-1.5 text-xs leading-relaxed text-brand-700/75">{t(`adv.${a.key}.desc` as any)}</p>
          </div>
        ))
      }
      </div>
    </div>
  </section>

  <!-- PRODUK UNGGULAN -->
  <section class="container-soft py-16 md:py-24">
    <div class="mx-auto max-w-2xl text-center">
      <p class="text-xs font-bold uppercase tracking-[0.2em] text-brand-500">{t("products.featuredLabel")}</p>
      <h2 class="mt-3 text-3xl font-extrabold text-brand-900 md:text-4xl">{t("products.featuredTitle")}</h2>
      <p class="mt-3 text-brand-700/80">{t("products.featuredSubtitle")}</p>
    </div>
    <div class="mx-auto mt-12 grid max-w-5xl grid-cols-1 gap-6 md:grid-cols-2">
      {featured.map((product) => <FeaturedProductCard product={product} lang={lang} />)}
    </div>
    <div class="mt-10 text-center">
      <a href={productsHref} class="inline-block rounded-full border border-brand-300 px-7 py-3 text-sm font-semibold text-brand-700 transition-colors hover:bg-brand-50">
        {t("cta.viewProducts")}
      </a>
    </div>
  </section>

  <!-- TESTIMONI — unggulan + foto -->
  <section class="container-soft py-16 md:py-24">
    <div class="mx-auto max-w-2xl text-center">
      <h2 class="text-3xl font-extrabold text-brand-900 md:text-4xl">{t("testi.title")}</h2>
      <p class="mt-3 text-brand-700/80">{t("testi.subtitle")}</p>
    </div>

    <div class="mt-12 grid items-stretch overflow-hidden rounded-3xl border border-brand-100 bg-white shadow-[var(--shadow-soft)] md:grid-cols-2">
      <img
        src="/products/set-bantal-guling-luxury.jpg"
        alt={t("testi.title")}
        loading="lazy"
        class="h-64 w-full object-cover md:h-full"
      />
      <div class="flex flex-col justify-center p-8 md:p-12">
        <svg class="text-brand-200" width="48" height="48" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M7.5 6C5 6 3 8 3 10.5S5 15 7.5 15c.2 0 .4 0 .6-.05C7.6 16.7 6.2 18 4.5 18.4c-.4.1-.6.5-.5.9.1.4.5.7.9.6C8.6 19.1 11 16 11 12v-1.5C11 8 9 6 7.5 6zm9 0C14 6 12 8 12 10.5S14 15 16.5 15c.2 0 .4 0 .6-.05-.5 1.75-1.9 3.05-3.6 3.45-.4.1-.6.5-.5.9.1.4.5.7.9.6C17.6 19.1 20 16 20 12v-1.5C20 8 18 6 16.5 6z"/></svg>

        <!-- Carousel teks testimoni (toggle + bisa di-swipe) -->
        <div id="testi-track" class="mt-3 select-none">
          {
            testimonials.map((item, i) => (
              <figure class:list={["testi-slide", { hidden: i !== 0 }]}>
                <div class="flex gap-1 text-brand-400">
                  {[0, 1, 2, 3, 4].map(() => (
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M12 3l2.6 5.3 5.9.9-4.3 4.1 1 5.8L12 16.9 6.8 19.2l1-5.8L3.5 9.2l5.9-.9z"/></svg>
                  ))}
                </div>
                <blockquote class="mt-4 text-lg leading-relaxed text-brand-800 md:text-xl">
                  “{item[lang].quote}”
                </blockquote>
                <figcaption class="mt-6 text-sm font-bold text-brand-900">
                  {item[lang].name}
                  <span class="font-normal text-brand-500"> · {item[lang].role}</span>
                </figcaption>
              </figure>
            ))
          }
        </div>

        <!-- Navigasi: panah + titik -->
        <div class="mt-8 flex items-center gap-4">
          <button type="button" id="testi-prev" aria-label="Sebelumnya" class="flex h-9 w-9 items-center justify-center rounded-full border border-brand-200 text-brand-600 transition-colors hover:bg-brand-50">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M15 6l-6 6 6 6"/></svg>
          </button>
          <div id="testi-dots" class="flex gap-2">
            {testimonials.map((_, i) => (
              <button type="button" class="testi-dot h-2.5 w-2.5 rounded-full bg-brand-200 transition-colors" data-i={i} aria-label={`Testimoni ${i + 1}`}></button>
            ))}
          </div>
          <button type="button" id="testi-next" aria-label="Berikutnya" class="flex h-9 w-9 items-center justify-center rounded-full border border-brand-200 text-brand-600 transition-colors hover:bg-brand-50">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 6l6 6-6 6"/></svg>
          </button>
        </div>
      </div>
    </div>
  </section>

  <script>
    const track = document.getElementById("testi-track");
    const slides = Array.from(document.querySelectorAll<HTMLElement>(".testi-slide"));
    const dots = Array.from(document.querySelectorAll<HTMLButtonElement>(".testi-dot"));
    const prev = document.getElementById("testi-prev");
    const next = document.getElementById("testi-next");

    if (track && slides.length) {
      let idx = 0;

      const show = (i: number) => {
        idx = (i + slides.length) % slides.length;
        slides.forEach((s, si) => s.classList.toggle("hidden", si !== idx));
        dots.forEach((d, di) => {
          d.classList.toggle("bg-brand-500", di === idx);
          d.classList.toggle("bg-brand-200", di !== idx);
        });
      };

      dots.forEach((d, i) => d.addEventListener("click", () => show(i)));
      prev?.addEventListener("click", () => show(idx - 1));
      next?.addEventListener("click", () => show(idx + 1));

      // Gesture swipe (sentuh) di area testimoni
      let startX = 0;
      track.addEventListener("touchstart", (e) => { startX = e.touches[0].clientX; }, { passive: true });
      track.addEventListener("touchend", (e) => {
        const dx = e.changedTouches[0].clientX - startX;
        if (Math.abs(dx) > 40) show(dx < 0 ? idx + 1 : idx - 1);
      }, { passive: true });

      show(0);
    }
  </script>

  <!-- CTA BAWAH -->
  <section class="container-soft pb-4">
    <div class="overflow-hidden rounded-3xl bg-gradient-to-br from-brand-600 to-brand-800 px-8 py-14 text-center text-white md:px-16">
      <h2 class="text-2xl font-extrabold md:text-3xl">{t("cta.bottomTitle")}</h2>
      <p class="mx-auto mt-3 max-w-xl text-brand-100">{t("cta.bottomSubtitle")}</p>
      <a
        href={orderHref}
        target="_blank"
        rel="noopener"
        class="mt-7 inline-block rounded-full bg-white px-8 py-3.5 text-sm font-bold text-brand-700 transition-transform hover:scale-105"
      >
        {t("cta.askWhatsapp")}
      </a>
    </div>
  </section>
</Layout>
