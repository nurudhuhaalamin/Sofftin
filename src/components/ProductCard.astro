---
import type { CollectionEntry } from "astro:content";
import { getLang, useTranslations, localizePath, formatPrice } from "../i18n/utils";
import { waLink } from "../config";
import { ui } from "../i18n/ui";

interface Props {
  product: CollectionEntry<"products">;
  lang: string;
}

const { product } = Astro.props;
const lang = getLang(Astro.props.lang);
const t = useTranslations(lang);
const d = product.data;

const name = d.name[lang];
const tagline = d.tagline?.[lang] ?? "";
const price = formatPrice(d.price);
const image = d.images[0] ? `/products/${d.images[0]}` : "/products/placeholder.svg";
const detailHref = localizePath(`/produk/${product.id}`, lang);
const orderHref = waLink(`${ui[lang]["wa.orderPrefix"]} ${name} (${price})`);
---

<article class="group flex flex-col overflow-hidden rounded-3xl border border-brand-100 bg-white shadow-[var(--shadow-soft)] transition-transform duration-300 hover:-translate-y-1">
  <a href={detailHref} class="block overflow-hidden bg-brand-50">
    <img
      src={image}
      alt={name}
      loading="lazy"
      class="aspect-[4/3] w-full object-cover transition-transform duration-500 group-hover:scale-105"
    />
  </a>
  <div class="flex flex-1 flex-col p-6">
    <h3 class="text-lg font-bold text-brand-900">
      <a href={detailHref} class="transition-colors hover:text-brand-500">{name}</a>
    </h3>
    {tagline && <p class="mt-1 text-sm text-brand-700/80">{tagline}</p>}
    <p class="mt-4 text-xl font-extrabold text-brand-600">{price}</p>

    <div class="mt-5 flex flex-col gap-2 sm:flex-row">
      <a
        href={orderHref}
        target="_blank"
        rel="noopener"
        class="flex-1 rounded-full bg-brand-500 px-4 py-2.5 text-center text-sm font-semibold text-white transition-colors hover:bg-brand-600"
      >
        {t("cta.buy")}
      </a>
      <a
        href={detailHref}
        class="flex-1 rounded-full border border-brand-200 px-4 py-2.5 text-center text-sm font-semibold text-brand-700 transition-colors hover:bg-brand-50"
      >
        {t("cta.viewDetail")}
      </a>
    </div>
  </div>
</article>
