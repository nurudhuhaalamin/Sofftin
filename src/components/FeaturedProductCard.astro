---
import type { CollectionEntry } from "astro:content";
import { getLang, useTranslations, localizePath, formatPrice } from "../i18n/utils";
import { waLink } from "../config";
import { ui } from "../i18n/ui";

interface Props {
  product: CollectionEntry<"products">;
  lang: string;
}

const { product } = Astro.props;
const lang = getLang(Astro.props.lang);
const t = useTranslations(lang);
const d = product.data;

const name = d.name[lang];
const tagline = d.tagline?.[lang] ?? "";
const price = formatPrice(d.price);
const original = d.originalPrice ? formatPrice(d.originalPrice) : null;
const image = d.images[0] ? `/products/${d.images[0]}` : "/products/placeholder.svg";
const specs = (d.specs?.[lang] ?? []).slice(0, 4);
const detailHref = localizePath(`/produk/${product.id}`, lang);
const orderHref = waLink(`${ui[lang]["wa.orderPrefix"]} ${name} (${price})`);
---

<!--
  Layout responsif:
  - Mobile & tablet (default): vertikal — gambar di atas, detail di bawah.
  - Desktop (lg): horizontal — gambar di kiri (panel biru), detail di kanan (sesuai mockup).
-->
<article class="grid overflow-hidden rounded-3xl border border-brand-100 bg-white shadow-[var(--shadow-soft)] lg:grid-cols-2">
  <a href={detailHref} class="flex items-center justify-center bg-brand-50 p-5">
    <img
      src={image}
      alt={name}
      loading="lazy"
      class="aspect-[4/3] w-full rounded-2xl object-cover lg:aspect-auto lg:h-full"
    />
  </a>

  <div class="flex flex-col justify-center p-6 md:p-8">
    <h3 class="text-xl font-extrabold text-brand-900">
      <a href={detailHref} class="transition-colors hover:text-brand-500">{name}</a>
    </h3>
    {tagline && <p class="mt-1.5 text-sm text-brand-700/80">{tagline}</p>}

    {
      specs.length > 0 && (
        <ul class="mt-4 space-y-2">
          {specs.map((s) => (
            <li class="flex items-start gap-2.5 text-sm text-brand-800">
              <svg class="mt-0.5 shrink-0 text-brand-500" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12.5l4 4 10-10" /></svg>
              {s}
            </li>
          ))}
        </ul>
      )
    }

    <div class="mt-6 flex flex-wrap items-baseline gap-x-2.5">
      {original && <span class="text-base font-medium text-brand-400 line-through">{original}</span>}
      <span class="text-2xl font-extrabold text-brand-600">{price}</span>
    </div>

    <div class="mt-5 flex flex-col gap-2.5 sm:flex-row">
      <a
        href={orderHref}
        target="_blank"
        rel="noopener"
        class="rounded-full bg-brand-500 px-6 py-3 text-center text-sm font-semibold text-white shadow-sm transition-colors hover:bg-brand-600"
      >
        {t("cta.buy")}
      </a>
      <a
        href={detailHref}
        class="rounded-full border border-brand-200 px-6 py-3 text-center text-sm font-semibold text-brand-700 transition-colors hover:bg-brand-50"
      >
        {t("cta.viewDetail")}
      </a>
    </div>
  </div>
</article>
