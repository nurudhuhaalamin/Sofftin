---
import { getLang, useTranslations, localizePath } from "../i18n/utils";
import { waLink } from "../config";
import { ui } from "../i18n/ui";

interface Props {
  lang: string;
  transparent?: boolean;
}
const lang = getLang(Astro.props.lang);
const transparent = Astro.props.transparent ?? false;
const t = useTranslations(lang);
const other = lang === "id" ? "en" : "id";

// Path saat ini tanpa prefix bahasa (untuk tombol ganti bahasa).
const segments = Astro.url.pathname.split("/").filter(Boolean);
const restPath = "/" + segments.slice(1).join("/");
const switchHref = localizePath(restPath === "/" ? "/" : restPath, other);

const nav = [
  { href: localizePath("/", lang), label: t("nav.home") },
  { href: localizePath("/produk", lang), label: t("nav.products") },
  { href: localizePath("/", lang) + "#keunggulan", label: t("nav.advantages") },
  { href: localizePath("/tentang", lang), label: t("nav.about") },
  { href: localizePath("/kontak", lang), label: t("nav.contact") },
];

const orderHref = waLink(ui[lang]["wa.general"]);
---

<header
  class:list={["site-header", { "is-solid": !transparent }]}
  data-transparent={String(transparent)}
>
  <div class="container-soft relative flex h-16 items-center justify-between gap-4 md:h-20">
    <!-- Logo (dua varian: putih utk transparan, biru utk solid) -->
    <a href={localizePath("/", lang)} class="flex shrink-0 items-center" aria-label="Softtin">
      <img src="/logo-softtin-white.png" alt="Softtin" class="logo-light h-11 w-auto md:h-14" />
      <img src="/logo-softtin.png" alt="Softtin" class="logo-dark h-11 w-auto md:h-14" />
    </a>

    <!-- Menu (di tengah) — tampil mulai tablet -->
    <nav class="absolute left-1/2 hidden -translate-x-1/2 items-center gap-8 md:flex">
      {
        nav.map((item) => (
          <a href={item.href} class="nav-link text-sm font-medium transition-opacity hover:opacity-70">
            {item.label}
          </a>
        ))
      }
    </nav>

    <!-- Aksi kanan -->
    <div class="flex items-center gap-2 md:gap-3">
      <a
        href={switchHref}
        class="header-lang rounded-full border px-3 py-1.5 text-xs font-semibold transition-colors"
        aria-label="Switch language"
      >
        {other.toUpperCase()}
      </a>
      <a
        href={orderHref}
        target="_blank"
        rel="noopener"
        class="hidden rounded-full bg-brand-500 px-5 py-2.5 text-sm font-semibold text-white shadow-sm transition-colors hover:bg-brand-600 sm:inline-block"
      >
        {t("cta.buy")}
      </a>

      <!-- Tombol menu mobile -->
      <button
        type="button"
        id="menu-toggle"
        class="header-burger inline-flex items-center justify-center rounded-lg p-2 md:hidden"
        aria-label="Menu"
        aria-expanded="false"
      >
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
          <line x1="4" y1="7" x2="20" y2="7"></line>
          <line x1="4" y1="12" x2="20" y2="12"></line>
          <line x1="4" y1="17" x2="20" y2="17"></line>
        </svg>
      </button>
    </div>
  </div>

  <!-- Menu mobile (drawer) -->
  <nav id="mobile-menu" class="hidden border-t border-brand-100 bg-white md:hidden">
    <div class="container-soft flex flex-col py-3">
      {
        nav.map((item) => (
          <a href={item.href} class="rounded-lg px-2 py-3 text-base font-medium text-brand-900 hover:bg-brand-50">
            {item.label}
          </a>
        ))
      }
      <a
        href={orderHref}
        target="_blank"
        rel="noopener"
        class="mt-2 rounded-full bg-brand-500 px-5 py-3 text-center text-sm font-semibold text-white"
      >
        {t("cta.buy")}
      </a>
    </div>
  </nav>
</header>

<script>
  const header = document.querySelector<HTMLElement>(".site-header");
  const toggle = document.getElementById("menu-toggle");
  const menu = document.getElementById("mobile-menu");

  // Buka/tutup menu mobile
  toggle?.addEventListener("click", () => {
    const open = menu?.classList.toggle("hidden");
    toggle.setAttribute("aria-expanded", String(open === false));
  });

  // Hanya halaman dengan header transparan yang berubah jadi solid saat scroll
  if (header?.dataset.transparent === "true") {
    const onScroll = () => {
      header.classList.toggle("is-solid", window.scrollY > 40);
    };
    onScroll();
    window.addEventListener("scroll", onScroll, { passive: true });
  }
</script>
