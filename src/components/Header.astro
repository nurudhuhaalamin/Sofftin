---
import { getLang, useTranslations, localizePath } from "../i18n/utils";
import { SITE, waLink } from "../config";
import { ui } from "../i18n/ui";

interface Props {
  lang: string;
}
const lang = getLang(Astro.props.lang);
const t = useTranslations(lang);
const other = lang === "id" ? "en" : "id";

// Path saat ini tanpa prefix bahasa (untuk tombol ganti bahasa).
const segments = Astro.url.pathname.split("/").filter(Boolean);
const restPath = "/" + segments.slice(1).join("/");
const switchHref = localizePath(restPath === "/" ? "/" : restPath, other);

const nav = [
  { href: localizePath("/", lang), label: t("nav.home") },
  { href: localizePath("/produk", lang), label: t("nav.products") },
  { href: localizePath("/", lang) + "#keunggulan", label: t("nav.advantages") },
  { href: localizePath("/tentang", lang), label: t("nav.about") },
  { href: localizePath("/kontak", lang), label: t("nav.contact") },
];

const orderHref = waLink(ui[lang]["wa.general"]);
---

<header class="sticky top-0 z-40 border-b border-brand-100 bg-white/90 backdrop-blur">
  <div class="container-soft relative flex h-16 items-center justify-between gap-4 md:h-20">
    <!-- Logo -->
    <a href={localizePath("/", lang)} class="flex shrink-0 items-center" aria-label="Softtin">
      <img src="/logo-softtin.png" alt="Softtin" class="h-9 w-auto md:h-11" />
    </a>

    <!-- Menu desktop (di tengah) -->
    <nav class="hidden items-center gap-8 lg:absolute lg:left-1/2 lg:flex lg:-translate-x-1/2">
      {
        nav.map((item) => (
          <a
            href={item.href}
            class="text-sm font-medium text-brand-900 transition-colors hover:text-brand-500"
          >
            {item.label}
          </a>
        ))
      }
    </nav>

    <!-- Aksi kanan -->
    <div class="flex items-center gap-2 md:gap-3">
      <a
        href={switchHref}
        class="rounded-full border border-brand-200 px-3 py-1.5 text-xs font-semibold text-brand-700 transition-colors hover:bg-brand-50"
        aria-label="Switch language"
      >
        {other.toUpperCase()}
      </a>
      <a
        href={orderHref}
        target="_blank"
        rel="noopener"
        class="hidden rounded-full bg-brand-500 px-5 py-2.5 text-sm font-semibold text-white shadow-sm transition-colors hover:bg-brand-600 sm:inline-block"
      >
        {t("cta.buy")}
      </a>

      <!-- Tombol menu mobile -->
      <button
        type="button"
        id="menu-toggle"
        class="inline-flex items-center justify-center rounded-lg p-2 text-brand-900 lg:hidden"
        aria-label="Menu"
        aria-expanded="false"
      >
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
          <line x1="4" y1="7" x2="20" y2="7"></line>
          <line x1="4" y1="12" x2="20" y2="12"></line>
          <line x1="4" y1="17" x2="20" y2="17"></line>
        </svg>
      </button>
    </div>
  </div>

  <!-- Menu mobile (drawer sederhana) -->
  <nav id="mobile-menu" class="hidden border-t border-brand-100 bg-white lg:hidden">
    <div class="container-soft flex flex-col py-3">
      {
        nav.map((item) => (
          <a
            href={item.href}
            class="rounded-lg px-2 py-3 text-base font-medium text-brand-900 hover:bg-brand-50"
          >
            {item.label}
          </a>
        ))
      }
      <a
        href={orderHref}
        target="_blank"
        rel="noopener"
        class="mt-2 rounded-full bg-brand-500 px-5 py-3 text-center text-sm font-semibold text-white"
      >
        {t("cta.buy")}
      </a>
    </div>
  </nav>
</header>

<script>
  const toggle = document.getElementById("menu-toggle");
  const menu = document.getElementById("mobile-menu");
  toggle?.addEventListener("click", () => {
    const open = menu?.classList.toggle("hidden");
    toggle.setAttribute("aria-expanded", String(open === false));
  });
</script>
